{
    "name": "fastaar/fastaar-laravel",
    "description": "Laravel package for the Fastaar payment gateway",
    "license": "MIT",
    "authors": [
        {
            "name": "Fastaar",
            "email": "support@fastaar.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "fastaar/fastaar-php": "^0.1.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^1.10|^2.0",
        "larastan/larastan": "^2.0|^3.0",
        "rector/rector": "^1.0|^2.0",
        "laravel/pint": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Fastaar\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fastaar\\Laravel\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fastaar\\Laravel\\FastaarServiceProvider"
            ],
            "aliases": {
                "Fastaar": "Fastaar\\Laravel\\Facades\\Fastaar"
            }
        }
    }
}
